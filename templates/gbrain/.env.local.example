# Copy this file to:
#   ~/Workspace/Projects/gbrain/.env.local
#
# Do not commit the copied file. Keep real API keys local.

# Database config. This is not a secret for the default local Docker setup.
GBRAIN_DATABASE_URL=postgresql://postgres:postgres@localhost:5436/gbrain

# Anthropic-compatible chat provider for query expansion and subagents.
# Use an Anthropic-compatible endpoint, or a third-party Claude proxy.
GBRAIN_ANTHROPIC_API_KEY=YOUR_ANTHROPIC_COMPATIBLE_API_KEY
GBRAIN_ANTHROPIC_BASE_URL=https://YOUR_ANTHROPIC_COMPATIBLE_ENDPOINT
GBRAIN_ANTHROPIC_MODEL=YOUR_CHAT_MODEL

GBRAIN_QUERY_EXPANSION_API_KEY=YOUR_ANTHROPIC_COMPATIBLE_API_KEY
GBRAIN_QUERY_EXPANSION_BASE_URL=https://YOUR_ANTHROPIC_COMPATIBLE_ENDPOINT
GBRAIN_QUERY_EXPANSION_MODEL=YOUR_FAST_CHAT_MODEL

GBRAIN_SUBAGENT_API_KEY=YOUR_ANTHROPIC_COMPATIBLE_API_KEY
GBRAIN_SUBAGENT_BASE_URL=https://YOUR_ANTHROPIC_COMPATIBLE_ENDPOINT
GBRAIN_SUBAGENT_MODEL=YOUR_STRONG_CHAT_MODEL

# OpenAI-compatible embedding provider.
# Aliyun DashScope text-embedding-v4 is the known-good 1536-dimension option.
GBRAIN_EMBED_API_KEY=YOUR_DASHSCOPE_API_KEY
GBRAIN_EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GBRAIN_EMBED_MODEL=text-embedding-v4
GBRAIN_EMBED_DIMENSIONS=1536
GBRAIN_EMBED_BATCH_SIZE=10

# Optional transcription provider. Leave empty unless you enable transcription.
GBRAIN_TRANSCRIPTION_API_KEY=
GBRAIN_TRANSCRIPTION_BASE_URL=
GBRAIN_TRANSCRIPTION_MODEL=
